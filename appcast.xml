    <!-- Previous release -->
    <item>
      <title>Version 0.2.1</title>
      <link>https://github.com/pingfan-hu/MiniNotes/releases/tag/v0.2.1</link>
      <sparkle:version>0.2.1</sparkle:version>
      <sparkle:shortVersionString>0.2.1</sparkle:shortVersionString>
      <description><![CDATA[
        <h2>What's New</h2>
        <ul>
          <li>Blockquote rendering: paragraphs starting with &gt; are now styled with a purple left border, lavender background, and purple text.</li>
          <li>Copy button: fenced code blocks now show a persistent copy button in the top-right corner.</li>
          <li>Global hotkey: use ⌃⌥⌘N (customizable in Settings → General) to show or hide the panel from anywhere.</li>
          <li>Settings: hotkey can be recorded by clicking the shortcut badge; reset to default with the circular arrow button.</li>
          <li>Settings: opening the Settings window now automatically closes the panel.</li>
        </ul>
      ]]></description>
      <pubDate>Thu, 17 Apr 2026 00:00:00 +0000</pubDate>
      <enclosure
        url="https://github.com/pingfan-hu/MiniNotes/releases/download/v0.2.1/MiniNotes-v0.2.1.dmg"
